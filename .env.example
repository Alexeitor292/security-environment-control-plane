# =============================================================================
# SECP-001 local development environment.
#
# Copy to `.env` (git-ignored) for the Docker Compose stack. EVERY value here is
# a DEVELOPMENT-ONLY placeholder and is UNSAFE FOR PRODUCTION. Do not put real
# secrets in this file or in `.env`. Production uses real OIDC, managed secrets,
# and encrypted transport (Charter §13).
# =============================================================================

# --- Application -------------------------------------------------------------
SECP_APP_ENV=dev
SECP_WORKFLOW_DISPATCH_MODE=inline          # inline | temporal

# --- Database (PostgreSQL in the dev stack) ----------------------------------
# DEV ONLY credentials.
POSTGRES_USER=secp
POSTGRES_PASSWORD=dev-only-postgres-password-change-me
POSTGRES_DB=secp
SECP_DATABASE_URL=postgresql+psycopg://secp:dev-only-postgres-password-change-me@postgres:5432/secp

# --- Object storage (MinIO) --------------------------------------------------
# DEV ONLY credentials.
MINIO_ROOT_USER=secp-dev
MINIO_ROOT_PASSWORD=dev-only-minio-password-change-me
SECP_S3_ENDPOINT=http://minio:9000
SECP_S3_BUCKET=secp-artifacts

# --- OIDC identity provider (Keycloak-compatible dev server) -----------------
# DEV ONLY credentials.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=dev-only-keycloak-password-change-me
SECP_OIDC_ISSUER=http://keycloak:8080/realms/secp
SECP_OIDC_AUDIENCE=secp-api
# Dev auth fallback principal is enabled only when APP_ENV != production.
SECP_AUTH_DEV_MODE=true

# --- Temporal (durable workflow engine) --------------------------------------
SECP_TEMPORAL_HOST=temporal:7233
SECP_TEMPORAL_NAMESPACE=default
SECP_TEMPORAL_TASK_QUEUE=secp-orchestration

# --- Web app -----------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8080

# --- SECP-B8 worker-owned live read-only discovery (optional) ----------------
# Only used when layering infra/dev/docker-compose.discovery-live.yml. The worker generates + OWNS
# its SSH + Ed25519 admission keypairs and assembles the mounted bundle automatically — so the ONLY
# host-side manual action is running the app-generated Proxmox bootstrap script. Nothing here is a
# secret; the worker's PRIVATE keys live only on the worker's persistent volume and are never here.
#
# Optional org id the worker publishes its PUBLIC node into. Leave empty for a single-org dev stack
# (auto-detected). Required only when more than one organization exists.
SECP_DISCOVERY_WORKER_NODE_ORGANIZATION=
SECP_DISCOVERY_WORKER_NODE_LABEL=default-worker
# B6 control-plane admission material (provisioned out of band; see
# docs/implementation/SECP-B6-discovery-bundle-mount.md). The endpoint MUST be strict HTTPS and the
# CA bundle MUST sign its server certificate; otherwise the worker stays sealed and fails closed.
SECP_DISCOVERY_ADMISSION_ENDPOINT=
SECP_DISCOVERY_ADMISSION_CA=

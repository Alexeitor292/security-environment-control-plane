{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://controlplane.security/schemas/v1alpha2/environment.json",
  "title": "Environment Definition (controlplane.security/v1alpha2)",
  "description": "Additive successor to v1alpha1 (ADR-016). Carries forward v1alpha1 and adds optional spec.topology and spec.publicationProvenance.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "$defs": {
    "topologyNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "label", "role", "ip", "network", "x", "y"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$" },
        "kind": { "enum": ["attacker", "target", "sensor", "network"] },
        "label": { "type": "string", "maxLength": 120 },
        "role": { "type": ["string", "null"], "maxLength": 200 },
        "ip": { "type": ["string", "null"], "pattern": "^\\d{1,3}(\\.\\d{1,3}){3}$" },
        "network": { "type": ["string", "null"], "maxLength": 200 },
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "topologyEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "target", "kind"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$" },
        "source": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$" },
        "target": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$" },
        "kind": { "enum": ["network", "monitors", "reaches"] }
      }
    },
    "topologyNetwork": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "cidr", "isolated"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$" },
        "label": { "type": "string", "maxLength": 120 },
        "cidr": { "type": ["string", "null"], "pattern": "^\\d{1,3}(\\.\\d{1,3}){3}/\\d{1,2}$" },
        "isolated": { "type": ["boolean", "null"] }
      }
    },
    "topologyZone": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "kind", "member_ids"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$" },
        "label": { "type": "string", "maxLength": 120 },
        "kind": { "type": ["string", "null"], "maxLength": 200 },
        "member_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$" }
        }
      }
    },
    "topology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "nodes", "edges", "networks", "zones"],
      "properties": {
        "schema_version": { "const": "secp.topology/v1" },
        "nodes": { "type": "array", "items": { "$ref": "#/$defs/topologyNode" } },
        "edges": { "type": "array", "items": { "$ref": "#/$defs/topologyEdge" } },
        "networks": { "type": "array", "items": { "$ref": "#/$defs/topologyNetwork" } },
        "zones": { "type": "array", "items": { "$ref": "#/$defs/topologyZone" } }
      }
    },
    "publicationProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "topology_document_id",
        "topology_revision_id",
        "topology_content_hash",
        "topology_validation_result_id",
        "topology_validation_result_hash",
        "base_environment_version_id",
        "publication_contract_version"
      ],
      "properties": {
        "topology_document_id": { "type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$" },
        "topology_revision_id": { "type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$" },
        "topology_content_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "topology_validation_result_id": { "type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$" },
        "topology_validation_result_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "base_environment_version_id": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        "publication_contract_version": { "const": "secp.publication/v1" }
      }
    }
  },
  "properties": {
    "apiVersion": {
      "const": "controlplane.security/v1alpha2"
    },
    "kind": {
      "const": "Environment"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
          "minLength": 1,
          "maxLength": 63
        },
        "displayName": { "type": "string", "maxLength": 128 },
        "description": { "type": "string", "maxLength": 2048 },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["teams", "networks", "roles", "requiredPlugins"],
      "properties": {
        "teams": {
          "type": "object",
          "additionalProperties": false,
          "required": ["count", "isolationPolicy"],
          "properties": {
            "count": { "type": "integer", "minimum": 1, "maximum": 64 },
            "isolationPolicy": { "enum": ["strict", "shared"] }
          }
        },
        "networks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "cidrStrategy"],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
              },
              "cidrStrategy": { "enum": ["per-team", "shared"] },
              "baseCidr": {
                "type": "string",
                "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$"
              },
              "isolated": { "type": "boolean", "default": true }
            }
          }
        },
        "roles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "kind", "image", "network"],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
              },
              "kind": { "enum": ["attacker", "target", "sensor", "service", "gateway"] },
              "image": { "type": "string", "minLength": 1 },
              "network": { "type": "string", "minLength": 1 },
              "count": { "type": "integer", "minimum": 1, "maximum": 16, "default": 1 },
              "vulnerabilityPacks": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "vulnerabilityPacks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref"],
            "properties": {
              "ref": { "type": "string", "minLength": 1 },
              "version": { "type": "string" }
            }
          }
        },
        "telemetry": {
          "type": "object",
          "additionalProperties": false,
          "required": ["providers"],
          "properties": {
            "providers": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["provider", "objectives"],
          "properties": {
            "provider": { "type": "string", "minLength": 1 },
            "objectives": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "description"],
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
                  },
                  "description": { "type": "string", "minLength": 1 },
                  "points": { "type": "integer", "minimum": 0, "default": 0 }
                }
              }
            }
          }
        },
        "requiredPlugins": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "resetPolicy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "strategy": { "enum": ["rebuild-from-baseline", "snapshot-restore"] }
          }
        },
        "destroyPolicy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "strategy": { "enum": ["full-teardown"] }
          }
        },
        "topology": { "$ref": "#/$defs/topology" },
        "publicationProvenance": { "$ref": "#/$defs/publicationProvenance" }
      }
    }
  }
}

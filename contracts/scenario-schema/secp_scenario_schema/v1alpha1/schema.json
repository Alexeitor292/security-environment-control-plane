{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://controlplane.security/schemas/v1alpha1/environment.json",
  "title": "Environment Definition (controlplane.security/v1alpha1)",
  "description": "Declarative environment definition schema. Breaking changes require a new apiVersion (ADR-002).",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "const": "controlplane.security/v1alpha1"
    },
    "kind": {
      "const": "Environment"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
          "minLength": 1,
          "maxLength": 63
        },
        "displayName": { "type": "string", "maxLength": 128 },
        "description": { "type": "string", "maxLength": 2048 },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["teams", "networks", "roles", "requiredPlugins"],
      "properties": {
        "teams": {
          "type": "object",
          "additionalProperties": false,
          "required": ["count", "isolationPolicy"],
          "properties": {
            "count": { "type": "integer", "minimum": 1, "maximum": 64 },
            "isolationPolicy": { "enum": ["strict", "shared"] }
          }
        },
        "networks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "cidrStrategy"],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
              },
              "cidrStrategy": { "enum": ["per-team", "shared"] },
              "baseCidr": {
                "type": "string",
                "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$"
              },
              "isolated": { "type": "boolean", "default": true }
            }
          }
        },
        "roles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "kind", "image", "network"],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
              },
              "kind": { "enum": ["attacker", "target", "sensor", "service", "gateway"] },
              "image": { "type": "string", "minLength": 1 },
              "network": { "type": "string", "minLength": 1 },
              "count": { "type": "integer", "minimum": 1, "maximum": 16, "default": 1 },
              "vulnerabilityPacks": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "vulnerabilityPacks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref"],
            "properties": {
              "ref": { "type": "string", "minLength": 1 },
              "version": { "type": "string" }
            }
          }
        },
        "telemetry": {
          "type": "object",
          "additionalProperties": false,
          "required": ["providers"],
          "properties": {
            "providers": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["provider", "objectives"],
          "properties": {
            "provider": { "type": "string", "minLength": 1 },
            "objectives": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "description"],
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
                  },
                  "description": { "type": "string", "minLength": 1 },
                  "points": { "type": "integer", "minimum": 0, "default": 0 }
                }
              }
            }
          }
        },
        "requiredPlugins": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "resetPolicy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "strategy": { "enum": ["rebuild-from-baseline", "snapshot-restore"] }
          }
        },
        "destroyPolicy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "strategy": { "enum": ["full-teardown"] }
          }
        }
      }
    }
  }
}

{
  "name": "secp-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "SECP-001 control-plane web app (React + TypeScript).",
  "scripts": {
    "dev": "vite --host --port 5173",
    "build": "tsc --noEmit && vite build",

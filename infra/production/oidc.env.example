# =============================================================================
# SECP production OIDC deployment — REFERENCE GUARDRAILS (ADR-019 / OIDC-C).
#
# This is a PLACEHOLDER-ONLY reference, NOT a turnkey production stack. It shows
# the environment guardrails a production deployment must satisfy. It contains
# NO secrets, NO client secret, NO private key, NO token, NO real hostname, and
# NO administrator credentials. Copy it into your deployment's secret manager /
# manifest tooling and replace every placeholder.
#
# DATABASE_URL and all other credentials are intentionally OMITTED — they come
# from the deployment's secret manager and must never be committed. Real
# provisioning and the complete real disposable-lab lifecycle remain sealed or
# incomplete; this file authorizes NO infrastructure action.
# =============================================================================

# --- Environment posture (all hard-refused-if-wrong by the Settings validator) ---
SECP_APP_ENV=production
# The dev auth fallback / bootstrap admin is forbidden in production.
SECP_AUTH_DEV_MODE=false
# Privileged work is dispatched to the durable worker, never run inline.
SECP_WORKFLOW_DISPATCH_MODE=temporal
# Provisioning stays sealed: neither the fake runner nor the real path is armed.
SECP_ENABLE_FAKE_PROVISIONING=false
SECP_ENABLE_REAL_PROVISIONING=false
SECP_ENABLE_OPENTOFU_SUBPROCESS=false

# --- Canonical public application origin (ADR-019) ---
# ONE exact HTTPS origin. The web app and the SECP API are served SAME-ORIGIN from it; the browser
# callback (…/auth/callback) and logout (…/login) URLs and the production Host allowlist derive from
# it. No userinfo/query/fragment, no path beyond '/', no wildcard. Replace the placeholder host.
SECP_PUBLIC_ORIGIN=https://secp.example.com

# Same-origin production => CORS is DISABLED. This MUST be empty (a non-empty value is refused).
SECP_CORS_ALLOW_ORIGINS=

# Optional: an additional internal hostname the edge/load balancer uses for liveness checks. A bare
# hostname only (never '*'); leave empty unless operationally required and documented.
#SECP_INTERNAL_HEALTH_HOST=

# --- Canonical external OIDC issuer (ADR-017) ---
# ONE canonical HTTPS issuer, externally operated (NOT bundled). The exact same string is returned to
# the browser, expected in the access-token `iss`, and used by the API for discovery + JWKS. No
# separate browser/internal/backchannel issuer. Replace the placeholder host.
SECP_OIDC_ISSUER=https://idp.example.com/realms/secp
# The access-token audience the API requires.
SECP_OIDC_AUDIENCE=secp-api
# The PUBLIC browser client id (a public client has NO secret; do not add one).
SECP_OIDC_WEB_CLIENT_ID=secp-web

# --- Bounded strict-verifier settings (ADR-017); conservative defaults shown ---
#SECP_OIDC_DISCOVERY_CACHE_SECONDS=300
#SECP_OIDC_JWKS_CACHE_SECONDS=300
#SECP_OIDC_HTTP_TIMEOUT_SECONDS=5.0
#SECP_OIDC_CLOCK_SKEW_SECONDS=60
#SECP_OIDC_MAX_TOKEN_BYTES=8192
#SECP_OIDC_MAX_DOCUMENT_BYTES=1048576

# --- Web build note (ADR-019) ---
# Do NOT set VITE_API_BASE_URL in a production web build: with it unset the browser uses its own
# (same) origin for the API, so the bearer only ever travels to the canonical origin.

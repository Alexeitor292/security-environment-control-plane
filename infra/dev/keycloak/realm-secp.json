{
  "realm": "secp",
  "enabled": true,
  "displayName": "SECP (development only — placeholder credentials, UNSAFE FOR PRODUCTION)",
  "sslRequired": "none",
  "registrationAllowed": false,
  "clients": [
    {
      "clientId": "secp-web",
      "name": "SECP Web (dev)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": ["http://localhost:5173/auth/callback"],
      "webOrigins": ["http://localhost:5173"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/login",
        "use.refresh.tokens": "false"
      },
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "secp-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "secp-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "secp-api",
      "name": "SECP API (dev)",
      "enabled": true,
      "publicClient": false,
      "secret": "dev-only-client-secret-change-me",
      "bearerOnly": true,
      "protocol": "openid-connect"
    }
  ],
  "roles": {
    "realm": [
      { "name": "platform-admin", "description": "DEV: all permissions" },
      { "name": "operator", "description": "DEV: operate exercises" },
      { "name": "approver", "description": "DEV: approve deployment plans" },
      { "name": "auditor", "description": "DEV: read audit log" }
    ]
  },
  "users": [
    {
      "id": "5ec9ad00-0000-4000-8000-000000000001",
      "username": "dev-admin",
      "enabled": true,
      "email": "dev-admin@local.test",
      "firstName": "Development",
      "lastName": "Admin",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "dev-only-admin-password-change-me",
          "temporary": false
        }
      ],
      "realmRoles": ["platform-admin"]
    }
  ]
}
